class Solution {
public:
    int minDeletion(vector<int>& nums) {
        int deletions = 0;

        for (int i = 0; i < nums.size() - 1; i++) {
         
            if ((i - deletions) % 2 == 0 && nums[i] == nums[i + 1]) {
                deletions++;
            }
        }

       
        if ((nums.size() - deletions) % 2 == 1) {
            deletions++;
        }

        return deletions;
    }
};
