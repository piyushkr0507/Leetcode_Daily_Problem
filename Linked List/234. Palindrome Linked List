class Solution {
public:
    bool isPalindrome(ListNode* head) {
        if (head == NULL || head->next == NULL) {
            return true;
        }

        ListNode* temp = head;
        int n = 0;

        while (temp) {
            n++;
            temp = temp->next;
        }

        int count = n / 2;

        ListNode* curr = head;
        ListNode* prev = NULL;

        while (count--) {
            prev = curr;
            curr = curr->next;
        }

        if (n % 2 == 1) {
            curr = curr->next;
        }

        prev->next = NULL;

        
        ListNode* previous = NULL;
        while (curr) {
            ListNode* front = curr->next;
            curr->next = previous;
            previous = curr;
            curr = front;
        }

        ListNode* head1 = head;
        ListNode* head2 = previous;

        while (head1 && head2) {
            if (head1->val != head2->val) {
                return false;
            }
            head1 = head1->next;
            head2 = head2->next;
        }

        return true;
    }
};
