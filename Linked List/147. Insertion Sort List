class Solution {
public:
    ListNode* insertionSortList(ListNode* head) {
        vector<int>ans;
        ListNode* temp = head;

        while(temp){
            ans.push_back(temp->val);
            temp = temp->next;
        }
         int n = ans.size();
        for(int i = 1; i< n; i++){
            for(int j = i; j > 0; j--){
                if(ans[j] < ans[j-1]){
                    swap(ans[j] , ans[j-1]);
                }
                else{
                    break;
                }
                
            }
        }

        temp = head;
        for(int i = 0; i<n; i++){
            temp->val = ans[i];
            temp = temp->next;
        }

        return head;
    }
};
