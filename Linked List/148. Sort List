class Solution {
public:
    ListNode* sortList(ListNode* head) {
        vector<int>ans;
        ListNode* temp = head;
        while(temp){
            ans.push_back(temp->val);
            temp = temp->next;
        }

        sort(ans.begin(), ans.end());

        temp = head;
        int n = ans.size();
        for(int i = 0; i<n; i++){
            temp->val = ans[i];
            temp = temp->next;
        }

        return head;
    }
};
