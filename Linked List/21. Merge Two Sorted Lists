# In C++ Language.

class Solution {
public:
    ListNode* mergeTwoLists(ListNode* head1, ListNode* head2) {
        ListNode* head = new ListNode(0);
        ListNode* tail = head;
        while(head1 && head2){
            if(head1->val <= head2->val){
                tail->next = head1;
                head1 = head1->next;
                tail = tail->next;
                tail->next = NULL;
            }
            else{
                tail->next = head2;
                head2 = head2->next;
                tail = tail->next;
                tail->next = NULL;
            }
        }
        if(head1){
            tail->next = head1;
        }
        else{
            tail->next = head2;
        }
        ListNode* ans = head->next;
        delete head;
    
    return ans;
    }
};
