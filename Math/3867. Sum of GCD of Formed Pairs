class Solution {
public:
    long long gcdSum(vector<int>& nums) {
        int n = nums.size();
        int mx = nums[0];
        vector<int> prefixgcd(n);

        
        for (int i = 0; i < n; i++) {
            mx = max(mx, nums[i]);
            prefixgcd[i] = gcd(nums[i], mx);   
        }

        sort(prefixgcd.begin(), prefixgcd.end());

        long long ans = 0;

        
        int i = 0, j = n - 1;
        while (i < j) {
            ans += gcd(prefixgcd[i], prefixgcd[j]);
            i++;
            j--;
        }
        return ans;
    }
};
